# FIXME: Configure environment variables for your project.
# Real secrets must NOT live here. Put production/preview values in the Vercel
# project settings, and local secrets in `.env.local` (which Git ignores).

# Database
# Local database with PGLite, already included in the project, no Docker needed.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/postgres

# Next.js
NEXT_TELEMETRY_DISABLED=1

# Logging
NEXT_PUBLIC_LOGGING_LEVEL=debug

# Local base URL for Auth0 redirects.
APP_BASE_URL=http://localhost:3000

######## [BEGIN] SENSITIVE DATA ######## For security reasons, do not put real
######## secrets here. Create `.env.local` (untracked by Git) and add them there.
# Auth0 (admin authentication). Placeholders below only satisfy build-time env
# validation — replace with real values in `.env.local` / Vercel.
AUTH0_SECRET=placeholder_auth0_secret_replace_me_with_32b
AUTH0_DOMAIN=example.us.auth0.com
AUTH0_CLIENT_ID=placeholder_client_id
AUTH0_CLIENT_SECRET=placeholder_client_secret
######## [END] SENSITIVE DATA
